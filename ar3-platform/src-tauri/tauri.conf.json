{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AR3 Platform",
  "version": "0.0.1",
  "identifier": "com.ar3.platform",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AR3 Platform",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../sidecar/server.py": "sidecar/server.py",
      "../sidecar/pyproject.toml": "sidecar/pyproject.toml",
      "../public/ar3.urdf": "public/ar3.urdf"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
