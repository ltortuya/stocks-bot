<?xml version="1.0"?>
<robot name="ar3">

  <!-- Materials -->
  <material name="base_grey"><color rgba="0.42 0.45 0.52 1"/></material>
  <material name="arm_blue"><color rgba="0.30 0.62 0.95 1"/></material>
  <material name="tcp_orange"><color rgba="0.95 0.55 0.20 1"/></material>

  <!-- Base (fixed to world) -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.085" rpy="0 0 0"/>
      <geometry><cylinder radius="0.075" length="0.17"/></geometry>
      <material name="base_grey"/>
    </visual>
  </link>

  <!-- Joint 1 — base rotation (Z-axis) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.17" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.97" upper="2.97" effort="10" velocity="1"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.055" length="0.08"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>

  <!-- Joint 2 — shoulder pitch (Y-axis) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.064 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.25" upper="2.25" effort="10" velocity="1"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.1525" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.305"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>

  <!-- Joint 3 — elbow pitch (Y-axis) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.305" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.50" upper="2.50" effort="10" velocity="1"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.06"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>

  <!-- Joint 4 — wrist roll (Z-axis, along forearm) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.88" upper="2.88" effort="5" velocity="1"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0.1115" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.223"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>

  <!-- Joint 5 — wrist pitch (Y-axis) -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.223" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.83" upper="1.83" effort="5" velocity="1"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.04"/></geometry>
      <material name="arm_blue"/>
    </visual>
  </link>

  <!-- Joint 6 — tool roll (Z-axis) -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.70" upper="2.70" effort="5" velocity="1"/>
  </joint>

  <link name="link6">
    <visual>
      <origin xyz="0 0 0.018" rpy="0 0 0"/>
      <geometry><cylinder radius="0.022" length="0.036"/></geometry>
      <material name="tcp_orange"/>
    </visual>
  </link>

</robot>
